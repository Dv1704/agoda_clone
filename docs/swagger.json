{
    "swagger": "2.0",
    "info": {
        "description": "Local orchestrator with benchmark and UI for Agoda data pipeline.",
        "title": "Agoda Data Pipeline API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8082",
    "basePath": "/api/v1",
    "paths": {
        "/run": {
            "post": {
                "description": "Start the Spark pipeline jobs and shadow testing",
                "produces": [
                    "application/json"
                ],
                "summary": "Trigger the pipeline",
                "responses": {
                    "200": {
                        "description": "Pipeline Started",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "409": {
                        "description": "Pipeline already running",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/status": {
            "get": {
                "description": "Get real-time logs and benchmark times",
                "produces": [
                    "application/json"
                ],
                "summary": "Get pipeline status and benchmarks",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.StatusResponse"
                        }
                    }
                }
            }
        },
        "/system": {
            "get": {
                "description": "Get CPU and Memory usage of the host system",
                "produces": [
                    "application/json"
                ],
                "summary": "Get system metrics",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.SystemMetrics"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "main.BenchmarkResult": {
            "type": "object",
            "properties": {
                "duration": {
                    "type": "string"
                },
                "end_time": {
                    "type": "string"
                },
                "start_time": {
                    "type": "string"
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "main.StatusResponse": {
            "type": "object",
            "properties": {
                "benchmark": {
                    "$ref": "#/definitions/main.BenchmarkResult"
                },
                "is_running": {
                    "type": "boolean"
                },
                "logs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "main.SystemMetrics": {
            "type": "object",
            "properties": {
                "cpu_percent": {
                    "type": "number"
                },
                "mem_percent": {
                    "type": "number"
                },
                "mem_total": {
                    "type": "integer"
                },
                "mem_used": {
                    "type": "integer"
                }
            }
        }
    }
}